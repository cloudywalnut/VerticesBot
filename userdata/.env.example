#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# Bot Settings - change to fit your deployment

BOT_NAME=Spark
PERSON=Customer
# Person, above, is what you call the person your bot chats with? (use singular)

# below word has to be usable as: has 'sales' potential or has 'hiring' potential
JOB=trading
INDIVIDUAL_CHATS=Yes
GROUP_ALLOWED=Yes
# Eg: exactly the names of your Whatsapp Groups: Customer Service,Welcome To My Group
GROUP_NAMES=

#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

# === USER CONFIGURABLE SETTINGS ===
# use only even numbers for HISTORY_SHORT & LONG
HISTORY_SHORT=8
HISTORY_LONG=26
localFormat=en-US
TimeZone=Asia/Kuala_Lumpur
BOT_PHONE=
BOSS_PHONE=
ASST_BOSS_PHONE=

#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

# === AI API Keys (fill in your own keys) ===
deepseekApi=
openaiApi=
qwenApi=
antApi=
localApi=
# WARNING: do not use Anthropic for GROUP CHATS (will crash because their prompt formats are different)

#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

# === VOICE SETTINGS ===
USEVOICE=Yes
VOICELANGUAGE=en
VOICE_API_KEY=
VOICE_MODEL_ID=eleven_turbo_v2_5
VOICE_ID=
# Leave VOICE_ID empty to use ElevenLabs default (Rachel). Set a specific ID to override.
VOICE_SPEED=1.00
VOICE_STABILITY=0.50
VOICE_SIMILARITY=0.50
VOICE_SPEAKER_BOOST=false

#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

# === AUTO SELECTION DURING RESTART (1 is Deepseek, 2 is OpenAI) ===
TYPE=Sock
AUTORUN=No
AUTO_CLEAR_CACHE=N
AUTO_ENGINE_CHOICE=1

#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

# === CONFIGURABLE DELAYS IN SECS ===
RESPONSE_DELAY_MIN_SEC=2
RESPONSE_DELAY_MAX_SEC=5
TYPING_DURATION_MIN_SEC=2
TYPING_DURATION_MAX_SEC=5
BOSS_NOTIFICATION_EXPIRY=60
MEDIA_EXPIRY_MINUTES=2
PERSONA_RELOAD_SECS=60
ENV_RELOAD_SECS=60

#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

# Vertices Wake and Sleep Settings
VerticesSleepMode=Off
WAKE_UP_HOUR=6
WAKE_UP_MINS=30
SLEEP_HOUR=3
SLEEP_MINS=59
LLM_TIMEOUT_MS=120000

#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

# RAG
RAG=On
VECTOR_DB_PATH=vectordb/rag.json

#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

# Market Scanner
MARKETSCANNER=Off
TA_FOLDER=
CHARTS_FOLDER=

#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

USE_HTTPS=No
PORT=2022
WEBDASHBOARD_USERNAME=admin
WEBDASHBOARD_PASSWORD=

#++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
