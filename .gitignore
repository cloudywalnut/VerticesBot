# WhatsApp session credentials - never commit these
userdata/whatsapp/

# Generated QR code
userdata/qr/

# Runtime data - auto-created on startup
userdata/chathistory/
userdata/mem/
userdata/img/
userdata/voice/

# Persona files - user-specific, auto-created on startup
userdata/persona/verticespersona-long.txt
userdata/persona/verticespersona-short.txt
userdata/persona/verticespersona-boss.txt
userdata/persona/verticespersona-group.txt

# Runtime JSON state - auto-created on startup
userdata/json/bot.log
userdata/json/bot-pid.json
userdata/json/pausedUsers.json
userdata/json/notifyboss-*.json
userdata/json/wa-status.json

# Allow env example - override the **/.env* rule above
!userdata/.env.example

# Notes File Not Needed on Github
notes.txt